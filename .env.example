# AXON - Bio-Robotics Edge Command System
# Copy to .env and adjust for local development.

# Application
AXON_ENV=development
AXON_PHASE=5
AXON_VERSION=0.5.0
AXON_SERVICE_NAME=axon-api

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Redis (Phase 1+)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MQTT / Mosquitto (Phase 1+)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=axon/v1

# Observability (Phase 7+)
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Learning (Phase 4+)
AXON_MLOPS_BACKEND=local
MLFLOW_TRACKING_URI=file:./artifacts/mlops/mlruns
AXON_DRIFT_WINDOW_SIZE=20
AXON_DRIFT_CONFIDENCE_THRESHOLD=0.60
AXON_DRIFT_CHECK_INTERVAL_SECONDS=30
AXON_MLOPS_SMOKE=false
AXON_SMOKE_DATASET_ROWS=100
AXON_SMOKE_SCENARIOS=3

# Sensor generators (Phase 1)
AXON_SCENARIO=normal_session
AXON_NODE_ID=rehab-node-01
AXON_ROBOT_ID=rehab-robot-01
AXON_PUBLISH_INTERVAL=1.0
AXON_SEED=42
AXON_TRACE_ID=session-synthetic-001

# Dashboard (browser-side; host accessible)
DASHBOARD_PORT=3000
AXON_API_WS_URL=ws://localhost:8000
ROS_DOMAIN_ID=42

# Phase 3 — LLM / Operator Copilot (mock by default)
AXON_LLM_MODE=mock
AXON_LLM_PROVIDER=mock
AXON_LLM_MODEL=mock-operator-copilot-v1
AXON_COPILOT_ENABLED=true
AXON_RAG_ENABLED=true
AXON_LLM_TIMEOUT_SECONDS=15
AXON_LLM_MAX_TOKENS=500

# Phase 3 — Safety thresholds
AXON_SAFETY_HIGH_RISK_THRESHOLD=0.75
AXON_SAFETY_LOW_CONFIDENCE_THRESHOLD=0.55
AXON_STALE_TELEMETRY_SECONDS=5

# Phase 3 — Agent loop / HITL
AXON_AGENT_LOOP_INTERVAL_SECONDS=5
AXON_HITL_EXPIRY_SECONDS=120
AXON_FAILURE_INJECTION_AUTO_RESET_SECONDS=30

# Phase 5 — Digital Twin timing contracts
TWIN_BROADCAST_HZ=5
SENSOR_STALE_TTL_SECONDS=5
SENSOR_DROPOUT_TTL_SECONDS=15
ROS2_TWIN_POLL_HZ=2

# Optional real LLM keys (leave empty for core/mock mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
