# AXON - Bio-Robotics Edge Command System
# Copy to .env and adjust for local development.

# Application
AXON_ENV=development
AXON_PHASE=0
AXON_VERSION=0.1.0
AXON_SERVICE_NAME=axon-api

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Redis (Phase 1+)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MQTT / Mosquitto (Phase 1+)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=axon/v1

# Observability (Phase 7+)
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Learning (Phase 4+)
MLFLOW_TRACKING_URI=http://localhost:5000

# ROS2 (Phase 5+)
ROS_DOMAIN_ID=42

# LLM copilot (Phase 3+, optional profile)
LLM_PROVIDER=
LLM_API_KEY=
